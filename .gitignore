# NOTA: en .gitignore los comentarios deben ir en su propia línea.
# git NO soporta comentarios al final de una línea de patrón; si los pones,
# el patrón deja de funcionar. Por eso aquí cada comentario va aparte.

# --- Python ---
# bytecode compilado
__pycache__/
*.py[cod]
# entorno virtual (cada quien lo recrea, no se versiona)
.venv/
venv/
*.egg-info/

# --- Base de datos local ---
# el archivo SQLite son datos locales, no código
*.db
*.sqlite3

# --- Variables de entorno / secretos ---
# nunca subir claves ni credenciales
.env

# --- Node / Vite (frontend) ---
# dependencias de npm (se reinstalan con npm install)
node_modules/
# build de producción generado
dist/
*.local

# --- Editores / OS ---
.vscode/
.idea/
# archivo basura que crea macOS
.DS_Store
