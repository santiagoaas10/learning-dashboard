# Variables de entorno del backend.
#
# Este archivo es una PLANTILLA documentada y SÍ se versiona. El archivo real
# con los valores (.env) está en .gitignore y nunca se sube: ahí viven los
# secretos. Para desarrollo local no necesitas crear nada: todos los valores
# tienen defaults pensados para desarrollo.

# Conexión a la base de datos.
# - Sin definir: SQLite local (backend/database.db).
# - Producción: la URL de Postgres que da Neon, p.ej.:
#   DATABASE_URL=postgresql://usuario:clave@host.neon.tech/neondb?sslmode=require
# DATABASE_URL=

# Clave con la que se FIRMAN los tokens JWT. Quien la conozca puede falsificar
# sesiones, por eso jamás se commitea. Generar una fuerte con:
#   openssl rand -hex 32
# SECRET_KEY=

# Orígenes permitidos para CORS, separados por coma (solo aplica cuando el
# frontend vive en otro dominio que la API; en desarrollo ya hay defaults).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
